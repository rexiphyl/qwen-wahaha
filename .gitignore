```gitignore
# Dependencies
.venv/
venv/
__pycache__/
*.pyc
*.pyo
*.pyd

# Build and distribution artifacts
build/
dist/
*.egg-info/

# Environment files
.env
.env.local
*.env.*

# Logs
*.log

# Coverage reports
.coverage
coverage/
htmlcov/

# IDE specific
.vscode/
.idea/
*.swp
*.swo
*.tmp

# OS generated files
.DS_Store
Thumbs.db
```